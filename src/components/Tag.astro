---
interface Props {
  name: string;
}
const { name } = Astro.props;
---
<a
  href={`/tags/${name}`}
  class="inline-flex items-center rounded-full border border-edge bg-surface px-2.5 py-0.5 text-xs font-medium text-soft hover:text-accent hover:border-accent/50 transition-colors"
>
  #{name}
</a>

---
import { formatDate, type Post } from '../lib/posts';
import { CATEGORIES } from '../lib/categories';
import Tag from './Tag.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props;
---
<article class="group relative rounded-2xl border border-edge bg-card p-6 transition-all hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5">
  <div class="flex items-center gap-2 text-xs font-medium uppercase tracking-wide">
    <a href={`/categories/${post.data.category}`} class="relative z-10 text-accent hover:text-accent-strong transition-colors">
      {CATEGORIES[post.data.category]}
    </a>
    <span class="text-soft" aria-hidden="true">·</span>
    <time datetime={post.data.pubDate.toISOString()} class="text-soft">
      {formatDate(post.data.pubDate)}
    </time>
  </div>
  <h2 class="mt-2 text-xl font-bold leading-snug">
    <a href={`/blog/${post.id}`} class="after:absolute after:inset-0 group-hover:text-accent transition-colors">
      {post.data.title}
    </a>
  </h2>
  <p class="mt-2 text-soft text-sm leading-relaxed">{post.data.description}</p>
  {
    post.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2 relative z-10">
        {post.data.tags.map((tag) => (
          <Tag name={tag} />
        ))}
      </div>
    )
  }
</article>

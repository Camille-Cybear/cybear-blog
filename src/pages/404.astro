---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import logo from '../assets/logo-cybear.png';
---
<Base title="Page introuvable — Cybear">
  <div class="py-20 text-center">
    <div class="inline-block opacity-70 logo-halo">
      <Image src={logo} alt="" width={160} class="h-20 w-auto" />
    </div>
    <h1 class="mt-6 text-4xl font-extrabold tracking-tight">404</h1>
    <p class="mt-3 text-soft">Cette page a hiberné quelque part… introuvable.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-xl brand-gradient px-5 py-2.5 font-semibold text-white hover:brightness-110 transition-all"
    >
      Retour à l'accueil
    </a>
  </div>
</Base>

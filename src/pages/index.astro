---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/posts';
import logo from '../assets/logo-cybear.png';

const posts = (await getPublishedPosts()).slice(0, 3);
---
<Base title="Cybear — veille techno & cybersécurité">
  <section class="py-8 sm:py-14">
    <div class="flex items-center gap-4 mb-6">
      <div class="logo-halo">
        <Image src={logo} alt="Logo Cybear — ours low-poly violet" width={192} class="h-16 sm:h-24 w-auto" loading="eager" />
      </div>
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight">
        Salut, moi c'est <span class="brand-text-gradient">Cybear</span> 🐾
      </h1>
    </div>
    <p class="text-lg text-soft leading-relaxed max-w-2xl">
      Technicien systèmes &amp; réseaux en reconversion, futur Administrateur
      d'Infrastructures Sécurisées. Ici je partage ma <strong class="text-ink font-semibold">veille technologique</strong> : sysadmin, réseaux, sécurité, scripting… tout ce qui passe entre mes griffes.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-xl brand-gradient px-5 py-2.5 font-semibold text-white hover:brightness-110 transition-all"
      >
        Lire le blog
      </a>
      <a
        href="/cv"
        class="inline-flex items-center gap-2 rounded-xl border border-edge bg-card px-5 py-2.5 font-semibold hover:border-accent/50 transition-colors"
      >
        Voir mon CV
      </a>
    </div>
  </section>

  <section class="mt-6">
    <div class="flex items-baseline justify-between mb-5">
      <h2 class="text-2xl font-bold">Derniers articles</h2>
      <a href="/blog" class="text-sm font-medium text-accent hover:text-accent-strong transition-colors">
        Tout voir →
      </a>
    </div>
    <div class="grid gap-4">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</Base>

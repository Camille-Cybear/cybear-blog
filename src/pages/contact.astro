---
import Base from '../layouts/Base.astro';

const LINKEDIN_URL = 'https://www.linkedin.com/in/camille-bonnefoy/';
---
<Base
  title="Contact — Cybear"
  description="Contacter Camille — opportunité d'alternance, question technique ou retour sur un article."
>
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Contact</h1>
  <p class="mt-3 text-soft max-w-2xl leading-relaxed">
    Une opportunité d'alternance, une question technique, un retour sur un article ?
    Laissez-moi un message, je réponds vite.
  </p>

  <div class="mt-8 rounded-2xl border border-edge bg-card p-6">
    <!-- TODO(camille): plug a form backend (Web3Forms / Formspree / Vercel function),
         then set the action and re-enable the submit button. -->
    <form class="grid gap-4" aria-describedby="contact-note">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="contact-name" class="block text-sm font-medium mb-1.5">Nom</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            autocomplete="name"
            class="w-full rounded-xl border border-edge bg-surface px-4 py-2.5 text-sm focus:outline-none focus:border-accent"
          />
        </div>
        <div>
          <label for="contact-email" class="block text-sm font-medium mb-1.5">Email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            autocomplete="email"
            class="w-full rounded-xl border border-edge bg-surface px-4 py-2.5 text-sm focus:outline-none focus:border-accent"
          />
        </div>
      </div>
      <div>
        <label for="contact-message" class="block text-sm font-medium mb-1.5">Message</label>
        <textarea
          id="contact-message"
          name="message"
          rows="6"
          class="w-full rounded-xl border border-edge bg-surface px-4 py-2.5 text-sm focus:outline-none focus:border-accent resize-y"
        ></textarea>
      </div>
      <div class="flex items-center gap-4 flex-wrap">
        <button
          type="submit"
          disabled
          class="inline-flex items-center gap-2 rounded-xl brand-gradient px-5 py-2.5 font-semibold text-white opacity-50 cursor-not-allowed"
        >
          Envoyer
        </button>
        <p id="contact-note" class="text-xs text-soft">
          ⏳ Formulaire en cours de mise en place — disponible très bientôt.
        </p>
      </div>
    </form>
  </div>

  <div class="mt-6 rounded-2xl border border-edge bg-card p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="text-sm text-soft">Vous préférez passer par LinkedIn ? C'est par ici :</p>
    <a
      href={LINKEDIN_URL}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 rounded-xl border border-edge bg-surface px-5 py-2.5 font-semibold hover:border-accent/50 transition-colors shrink-0"
    >
      Mon profil LinkedIn
    </a>
  </div>
</Base>

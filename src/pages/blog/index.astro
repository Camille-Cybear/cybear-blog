---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryPills from '../../components/CategoryPills.astro';
import { getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
---
<Base title="Blog — Cybear" description="Tous les articles de veille technologique de Cybear.">
  <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Blog</h1>
  <p class="mt-3 text-soft">
    {posts.length} article{posts.length > 1 ? 's' : ''} de veille — réseaux, sécurité, systèmes et autres trouvailles.
  </p>

  <div class="mt-6">
    <CategoryPills />
  </div>

  <div class="mt-8 grid gap-4">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</Base>

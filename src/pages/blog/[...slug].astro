---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Tag from '../../components/Tag.astro';
import { getPublishedPosts, formatDate, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} — Cybear`} description={post.data.description}>
  <article>
    <header class="mb-8">
      <a href="/blog" class="text-sm font-medium text-accent hover:text-accent-strong transition-colors">
        ← Retour au blog
      </a>
      <h1 class="mt-4 text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight">
        {post.data.title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-soft">
        <time datetime={post.data.pubDate.toISOString()}>
          Publié le {formatDate(post.data.pubDate)}
        </time>
        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <Tag name={tag} />
              ))}
            </div>
          )
        }
      </div>
    </header>

    <div class="prose dark:prose-invert max-w-none prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-headings:tracking-tight prose-img:rounded-xl">
      <Content />
    </div>
  </article>
</Base>
